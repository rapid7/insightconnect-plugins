import os
import json
from sys import argv

Name = "RPM"
Vendor = "rapid7"
Version = "1.0.2"
Description = "The RPM plugin allows you to download and analyze an RPM package"


def main():
    if 'http' in argv:
        if os.environ.get("GUNICORN_CONFIG_FILE"):
            with open(os.environ.get("GUNICORN_CONFIG_FILE")) as gf:
                gunicorn_cfg = json.load(gf)
                if gunicorn_cfg.get("worker_class", "sync") == "gevent":
                    from gevent import monkey
                    monkey.patch_all()
        elif 'gevent' in argv:
            from gevent import monkey
            monkey.patch_all()

    import insightconnect_plugin_runtime
    from komand_rpm import connection, actions, triggers, tasks

    class ICONRpm(insightconnect_plugin_runtime.Plugin):
        def __init__(self):
            super(self.__class__, self).__init__(
                name=Name,
                vendor=Vendor,
                version=Version,
                description=Description,
                connection=connection.Connection()
            )
            self.add_action(actions.Info())
        

    """Run plugin"""
    cli = insightconnect_plugin_runtime.CLI(ICONRpm())
    cli.run()


if __name__ == "__main__":
    main()
